{{!-- Blue Planet Damage Roll Chat Message Template --}}
<div class="blue-planet-roll-message damage-roll">
  <div class="roll-header">
    <h4 class="roll-title">
      <i class="fas fa-sword"></i>
      {{#if weapon}}
        {{weapon}} Damage
      {{else}}
        Damage Roll
      {{/if}}
    </h4>
    <div class="damage-type">
      {{#if damageType}}
        Type: {{damageType}}
      {{/if}}
    </div>
  </div>
  
  <div class="roll-details">
    <div class="dice-result">
      <span class="roll-formula">{{roll.formula}}</span>
      <span class="roll-total damage-total">
        = {{roll.total}} damage
      </span>
    </div>
    
    {{#if roll.total}}
      <div class="damage-result">
        <div class="damage-breakdown">
          {{#if roll.terms}}
            {{#each roll.terms as |term|}}
              {{#if term.results}}
                <div class="dice-breakdown">
                  {{#each term.results as |result|}}
                    <span class="die-result {{#if result.active}}active{{/if}}">
                      {{result.result}}
                    </span>
                  {{/each}}
                </div>
              {{/if}}
            {{/each}}
          {{/if}}
        </div>
        
        {{#if woundLevel}}
          <div class="wound-level {{woundLevel}}">
            <i class="fas fa-heart-broken"></i>
            {{#if (eq woundLevel "minor")}}
              Minor Wound (-1)
            {{else if (eq woundLevel "major")}}
              Major Wound (-2)
            {{else if (eq woundLevel "mortal")}}
              Mortal Wound (-3)
            {{/if}}
          </div>
        {{/if}}
      </div>
    {{/if}}
    
    {{#if armor}}
      <div class="armor-info">
        <i class="fas fa-shield-alt"></i>
        Armor: {{armor.value}} ({{armor.type}})
        {{#if armorPenetration}}
          | AP: {{armorPenetration}}
        {{/if}}
      </div>
    {{/if}}
  </div>
  
  {{#if flavor}}
    <div class="flavor-text">
      {{flavor}}
    </div>
  {{/if}}
</div>

<style>
.blue-planet-roll-message.damage-roll {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.8) 0%, rgba(160, 82, 45, 0.8) 100%);
  border: 2px solid #d2691e;
}

.blue-planet-roll-message.damage-roll .roll-title {
  color: #ffa500;
}

.blue-planet-roll-message.damage-roll .roll-title i {
  color: #d2691e;
}

.blue-planet-roll-message .damage-type {
  font-size: 12px;
  color: #deb887;
  font-weight: bold;
}

.blue-planet-roll-message .damage-total {
  font-size: 18px;
  color: #ff6347;
  text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.7);
  font-weight: bold;
}

.blue-planet-roll-message .damage-result {
  margin: 10px 0;
  text-align: center;
}

.blue-planet-roll-message .damage-breakdown {
  margin: 8px 0;
}

.blue-planet-roll-message .dice-breakdown {
  display: flex;
  justify-content: center;
  gap: 5px;
  margin: 5px 0;
}

.blue-planet-roll-message .die-result {
  display: inline-block;
  width: 24px;
  height: 24px;
  line-height: 24px;
  text-align: center;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid #666;
  border-radius: 3px;
  font-size: 12px;
  font-weight: bold;
}

.blue-planet-roll-message .die-result.active {
  background: rgba(210, 105, 30, 0.4);
  border-color: #d2691e;
  color: #ffa500;
}

.blue-planet-roll-message .wound-level {
  padding: 8px 12px;
  border-radius: 4px;
  font-weight: bold;
  margin: 8px 0;
  text-align: center;
}

.blue-planet-roll-message .wound-level.minor {
  background: rgba(255, 193, 7, 0.2);
  border: 1px solid #ffc107;
  color: #ffc107;
}

.blue-planet-roll-message .wound-level.major {
  background: rgba(255, 152, 0, 0.2);
  border: 1px solid #ff9800;
  color: #ff9800;
}

.blue-planet-roll-message .wound-level.mortal {
  background: rgba(244, 67, 54, 0.2);
  border: 1px solid #f44336;
  color: #f44336;
}

.blue-planet-roll-message .wound-level i {
  margin-right: 5px;
}

.blue-planet-roll-message .armor-info {
  font-size: 12px;
  color: #b8d4f0;
  text-align: center;
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid rgba(210, 105, 30, 0.3);
}

.blue-planet-roll-message .armor-info i {
  margin-right: 5px;
  color: #d2691e;
}
</style>
