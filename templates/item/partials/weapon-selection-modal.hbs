{{!-- Weapon Selection Modal for Ammunition Compatibility --}}
<div class="weapon-selection-modal">
  <div class="modal-content">
    
    <header class="modal-header">
      <h2><i class="fas fa-crosshairs"></i> Select Compatible Weapons</h2>
      <button type="button" class="close-modal" data-action="close-modal">
        <i class="fas fa-times"></i>
      </button>
    </header>
    
    <div class="modal-body">
      
      {{!-- Search/Filter Section --}}
      <div class="weapon-filter-section">
        <div class="filter-controls">
          <div class="search-group">
            <i class="fas fa-search"></i>
            <input type="text" class="weapon-search" placeholder="Search weapons by name..." autocomplete="off">
          </div>
          <div class="filter-group">
            <select class="weapon-type-filter">
              <option value="">All Weapon Types</option>
              <option value="pistol">Pistols</option>
              <option value="rifle">Rifles</option>
              <option value="shotgun">Shotguns</option>
              <option value="submachine_gun">Submachine Guns</option>
              <option value="assault_rifle">Assault Rifles</option>
              <option value="sniper_rifle">Sniper Rifles</option>
              <option value="machine_gun">Machine Guns</option>
              <option value="grenade_launcher">Grenade Launchers</option>
              <option value="exotic">Exotic Weapons</option>
            </select>
          </div>
        </div>
      </div>
      
      {{!-- Available Weapons List --}}
      <div class="available-weapons-section">
        <h3>Available Weapons</h3>
        <div class="weapons-grid">
          
          {{#if availableWeapons.length}}
            {{#each availableWeapons as |weapon|}}
            <div class="weapon-selection-item" data-weapon-id="{{weapon.id}}">
              <div class="weapon-checkbox">
                <input type="checkbox" 
                       id="weapon-{{weapon.id}}" 
                       data-weapon-id="{{weapon.id}}"
                       {{#if weapon.isSelected}}checked{{/if}}>
                <label for="weapon-{{weapon.id}}"></label>
              </div>
              
              <div class="weapon-info-card">
                <div class="weapon-header">
                  <div class="weapon-icon">
                    {{#if weapon.img}}
                      <img src="{{weapon.img}}" alt="{{weapon.name}}">
                    {{else}}
                      <i class="fas fa-gun"></i>
                    {{/if}}
                  </div>
                  <div class="weapon-title">
                    <h4>{{weapon.name}}</h4>
                    <span class="weapon-type">{{titleCase weapon.system.weapon_type}}</span>
                  </div>
                </div>
                
                <div class="weapon-stats">
                  <div class="stat">
                    <i class="fas fa-bullseye"></i>
                    <span>Damage: {{weapon.system.damage}}</span>
                  </div>
                  {{#if (ne weapon.system.weapon_type "melee")}}
                  <div class="stat">
                    <i class="fas fa-crosshairs"></i>
                    <span>Range: {{weapon.system.effective_range}}m</span>
                  </div>
                  {{/if}}
                  {{#if weapon.system.magazine_capacity}}
                  <div class="stat">
                    <i class="fas fa-circle-dot"></i>
                    <span>Capacity: {{weapon.system.magazine_capacity}}</span>
                  </div>
                  {{/if}}
                </div>
                
                {{#if weapon.system.description}}
                <div class="weapon-description">
                  <p>{{truncate weapon.system.description 120}}</p>
                </div>
                {{/if}}
              </div>
            </div>
            {{/each}}
            
          {{else}}
            <div class="no-weapons-available">
              <i class="fas fa-search"></i>
              <p><strong>No weapons found</strong></p>
              <p class="help-text">No weapons match your current filter criteria.</p>
            </div>
          {{/if}}
          
        </div>
      </div>
      
      {{!-- Selected Weapons Summary --}}
      <div class="selected-weapons-section">
        <h3>Selected Weapons (<span class="selection-count">0</span>)</h3>
        <div class="selected-weapons-list">
          {{!-- Populated dynamically via JavaScript --}}
          <div class="no-selection">
            <i class="fas fa-hand-pointer"></i>
            <p><em>No weapons selected yet</em></p>
          </div>
        </div>
      </div>
      
    </div>
    
    <footer class="modal-footer">
      <div class="modal-actions">
        <button type="button" class="modal-btn cancel-btn" data-action="cancel-selection">
          <i class="fas fa-times"></i> Cancel
        </button>
        <button type="button" class="modal-btn clear-btn" data-action="clear-selection">
          <i class="fas fa-eraser"></i> Clear All
        </button>
        <button type="button" class="modal-btn confirm-btn" data-action="confirm-selection">
          <i class="fas fa-check"></i> Add Selected Weapons
        </button>
      </div>
    </footer>
    
  </div>
</div>

{{!-- Modal Styles --}}
<style>
.weapon-selection-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #2a2a2a;
  border: 2px solid #d4af37;
  border-radius: 8px;
  width: 90%;
  max-width: 900px;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8px 32px rgba(212, 175, 55, 0.3);
}

.modal-header {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2508 100%);
  padding: 16px 20px;
  border-bottom: 1px solid #d4af37;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h2 {
  margin: 0;
  color: #d4af37;
  font-size: 18px;
}

.close-modal {
  background: none;
  border: none;
  color: #ccc;
  font-size: 18px;
  cursor: pointer;
  padding: 4px;
  border-radius: 4px;
  transition: all 0.2s ease;
}

.close-modal:hover {
  background: #d4af37;
  color: #000;
}

.modal-body {
  padding: 16px 20px;
  overflow-y: auto;
  flex: 1;
}

.weapon-filter-section {
  margin-bottom: 20px;
}

.filter-controls {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.search-group, .filter-group {
  position: relative;
  flex: 1;
  min-width: 200px;
}

.search-group i {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #d4af37;
  z-index: 1;
}

.weapon-search, .weapon-type-filter {
  width: 100%;
  padding: 8px 12px 8px 36px;
  background: #333;
  border: 1px solid #555;
  border-radius: 4px;
  color: #fff;
}

.weapon-type-filter {
  padding-left: 12px;
}

.weapons-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 12px;
  max-height: 300px;
  overflow-y: auto;
  padding: 8px;
  border: 1px solid #555;
  border-radius: 4px;
  background: #1a1a1a;
}

.weapon-selection-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px;
  background: #2a2a2a;
  border: 1px solid #444;
  border-radius: 4px;
  transition: all 0.2s ease;
}

.weapon-selection-item:hover {
  border-color: #d4af37;
  background: #333;
}

.weapon-selection-item.selected {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.1);
}

.weapon-checkbox {
  position: relative;
}

.weapon-checkbox input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: #d4af37;
}

.weapon-info-card {
  flex: 1;
}

.weapon-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.weapon-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #444;
  border-radius: 4px;
}

.weapon-icon img {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.weapon-icon i {
  color: #d4af37;
  font-size: 16px;
}

.weapon-title h4 {
  margin: 0;
  font-size: 14px;
  color: #fff;
}

.weapon-title .weapon-type {
  font-size: 11px;
  color: #aaa;
}

.weapon-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}

.weapon-stats .stat {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: #ccc;
}

.weapon-stats .stat i {
  color: #d4af37;
  font-size: 10px;
}

.weapon-description p {
  font-size: 10px;
  color: #aaa;
  margin: 0;
  line-height: 1.3;
}

.selected-weapons-section {
  margin-top: 20px;
  border-top: 1px solid #555;
  padding-top: 16px;
}

.selected-weapons-section h3 {
  color: #d4af37;
  margin-bottom: 12px;
}

.selection-count {
  color: #fff;
  background: #d4af37;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
}

.selected-weapons-list {
  max-height: 120px;
  overflow-y: auto;
  padding: 8px;
  background: #1a1a1a;
  border: 1px solid #555;
  border-radius: 4px;
}

.modal-footer {
  padding: 16px 20px;
  border-top: 1px solid #555;
  background: #1a1a1a;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.modal-btn {
  padding: 8px 16px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  gap: 6px;
}

.cancel-btn {
  background: #555;
  color: #fff;
}

.cancel-btn:hover {
  background: #666;
}

.clear-btn {
  background: #cc4444;
  color: #fff;
}

.clear-btn:hover {
  background: #dd5555;
}

.confirm-btn {
  background: #d4af37;
  color: #000;
}

.confirm-btn:hover {
  background: #f4d03f;
}
</style>