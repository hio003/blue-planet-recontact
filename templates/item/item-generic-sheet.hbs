<form class="{{cssClass}} flexcol item-sheet" autocomplete="off">

  {{!-- Header --}}
  <header class="sheet-header">
    <div class="header-fields">
      <div class="name-section">
        <input name="name" type="text" value="{{item.name}}" placeholder="Item Name" class="item-name"/>
        <div class="item-type-line">
          <span class="item-type">{{titleCase item.type}}</span>
        </div>
      </div>
    </div>
  </header>

  {{!-- Main Content --}}
  <section class="sheet-main">
    
    {{!-- Navigation Tabs --}}
    <nav class="sheet-tabs" data-group="primary">
      <a class="item active" data-tab="description">DESCRIPTION</a>
      {{#if (eq item.type "skill")}}
        <a class="item" data-tab="skill-data">SKILL DATA</a>
      {{/if}}
      {{#if (eq item.type "species")}}
        <a class="item" data-tab="species-data">SPECIES DATA</a>
      {{/if}}
      <a class="item" data-tab="properties">PROPERTIES</a>
    </nav>

    {{!-- Tab Content --}}
    <section class="sheet-body">
      
      {{!-- Description Tab --}}
      <div class="tab description active" data-group="primary" data-tab="description">
        <div class="description-section">
          <label>Description:</label>
          <textarea name="system.description" placeholder="Item description and details">{{system.description}}</textarea>
        </div>
      </div>

      {{!-- Skill Data Tab --}}
      {{#if (eq item.type "skill")}}
      <div class="tab skill-data" data-group="primary" data-tab="skill-data">
        <div class="skill-section">
          
          <div class="skill-info">
            <div class="property-group">
              <label>Skill Rank:</label>
              <input type="number" name="system.rank" value="{{system.rank}}" min="1" max="10" class="skill-rank">
            </div>
            
            <div class="property-group">
              <label>Category:</label>
              <select name="system.category">
                {{#each skillCategories as |label key|}}
                  <option value="{{key}}" {{#if (eq ../system.category key)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
          </div>
          
          <div class="skill-levels">
            <h3>Skill Levels</h3>
            
            <div class="property-group">
              <label>General Level:</label>
              <input type="text" name="system.levels.general" value="{{system.levels.general}}" placeholder="General skill description">
            </div>
            
            <div class="property-group">
              <label>Core Level:</label>
              <input type="text" name="system.levels.core" value="{{system.levels.core}}" placeholder="Core skill specialization">
            </div>
            
            <div class="property-group">
              <label>Specialty Level:</label>
              <input type="text" name="system.levels.specialty" value="{{system.levels.specialty}}" placeholder="Specialty focus">
            </div>
          </div>
          
          <div class="skill-notes">
            <h4>Skill Level Guidelines:</h4>
            <ul>
              <li><strong>General (Rank 1-3):</strong> Basic familiarity and training</li>
              <li><strong>Core (Rank 4-6):</strong> Professional competence and specialization</li>
              <li><strong>Specialty (Rank 7-10):</strong> Expert mastery and unique focus</li>
            </ul>
          </div>
          
        </div>
      </div>
      {{/if}}

      {{!-- Species Data Tab --}}
      {{#if (eq item.type "species")}}
      <div class="tab species-data" data-group="primary" data-tab="species-data">
        <div class="species-section">
          
          <div class="species-attributes">
            <h3>Attribute Modifiers</h3>
            
            <div class="attribute-mods">
              <div class="property-group">
                <label>Cognition:</label>
                <input type="number" name="system.attributes.cognition" value="{{system.attributes.cognition}}" min="-2" max="3" class="species-attribute" data-attribute="cognition">
              </div>
              
              <div class="property-group">
                <label>Psyche:</label>
                <input type="number" name="system.attributes.psyche" value="{{system.attributes.psyche}}" min="-2" max="3" class="species-attribute" data-attribute="psyche">
              </div>
              
              <div class="property-group">
                <label>Coordination:</label>
                <input type="number" name="system.attributes.coordination" value="{{system.attributes.coordination}}" min="-2" max="3" class="species-attribute" data-attribute="coordination">
              </div>
              
              <div class="property-group">
                <label>Physique:</label>
                <input type="number" name="system.attributes.physique" value="{{system.attributes.physique}}" min="-2" max="3" class="species-attribute" data-attribute="physique">
              </div>
            </div>
          </div>
          
          <div class="species-traits">
            <div class="property-group">
              <label>Size Category:</label>
              <select name="system.size_category">
                {{#each sizeCategories as |label key|}}
                  <option value="{{key}}" {{#if (eq ../system.size_category key)}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </div>
            
            <div class="special-abilities">
              <h4>Special Abilities:</h4>
              <textarea name="system.special_abilities" placeholder="List special racial abilities and traits">{{join system.special_abilities "\n"}}</textarea>
            </div>
          </div>
          
        </div>
      </div>
      {{/if}}

      {{!-- Properties Tab --}}
      <div class="tab properties" data-group="primary" data-tab="properties">
        <div class="properties-section">
          
          {{#if (ne item.type "skill")}}
          <div class="property-group">
            <label>Cost:</label>
            <input type="number" name="system.cost" value="{{system.cost}}" min="0" step="0.01">
          </div>
          
          <div class="property-group">
            <label>Availability:</label>
            <select name="system.availability">
              {{#each availabilityOptions as |label key|}}
                <option value="{{key}}" {{#if (eq ../system.availability key)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          
          <div class="property-group">
            <label>Legality:</label>
            <select name="system.legality">
              {{#each legalityOptions as |label key|}}
                <option value="{{key}}" {{#if (eq ../system.legality key)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          {{/if}}
          
          {{#if (eq item.type "feature")}}
          <div class="property-group">
            <label>Feature Type:</label>
            <select name="system.type">
              {{#each featureTypes as |label key|}}
                <option value="{{key}}" {{#if (eq ../system.type key)}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          
          <div class="property-group">
            <label>Effect:</label>
            <textarea name="system.effect" placeholder="Mechanical effect of this feature">{{system.effect}}</textarea>
          </div>
          {{/if}}
          
          <div class="item-info">
            {{#if (eq item.type "skill")}}
            <h4>About Skills:</h4>
            <p>Skills represent learned abilities and areas of expertise. Characters improve skills through training and experience.</p>
            {{else if (eq item.type "feature")}}
            <h4>About Features:</h4>
            <p>Features represent character traits, advantages, disadvantages, and quirks that define personality and capabilities.</p>
            {{else if (eq item.type "species")}}
            <h4>About Species:</h4>
            <p>Species define the baseline characteristics and special abilities of different character races.</p>
            {{/if}}
          </div>
          
        </div>
      </div>

    </section>
  </section>

</form>
