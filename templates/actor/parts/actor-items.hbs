{{!-- Items Section --}}
<div class="items">
  
  {{#if weapons.length}}
  <div class="items-section">
    <h3>WEAPONS</h3>
    <ul class="item-list">
      {{#each weapons as |item|}}
      <li class="item" data-item-id="{{item._id}}">
        <div class="item-name">
          <h4>{{item.name}}</h4>
          <div class="item-details">
            {{#if system.weapon_type}}<span class="weapon-type">{{capitalize system.weapon_type}}</span>{{/if}}
            {{#if system.damage}}<span class="weapon-damage">Damage: {{system.damage}}</span>{{/if}}
            {{#if system.effective_range}}<span class="weapon-range">Range: {{system.effective_range}}m</span>{{/if}}
          </div>
        </div>
        <div class="item-controls">
          <a class="item-control weapon-damage-roll" data-item-id="{{item._id}}" title="Damage Roll"><i class="fas fa-heart-broken"></i></a>
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}
  
  {{#if equipment.length}}
  <div class="items-section">
    <h3>EQUIPMENT</h3>
    <ul class="item-list">
      {{#each equipment as |item|}}
      <li class="item" data-item-id="{{item._id}}">
        <div class="item-name">
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-controls">
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}
  
  {{#if biomods.length}}
  <div class="items-section">
    <h3>BIOMODS</h3>
    <ul class="item-list">
      {{#each biomods as |item|}}
      <li class="item" data-item-id="{{item._id}}">
        <div class="item-name">
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-controls">
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}
  
</div>
