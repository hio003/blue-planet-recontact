<form class="{{cssClass}} flexcol" autocomplete="off">
  
  {{!-- Header --}}
  <header class="sheet-header">
    <div class="header-content">
      {{!-- Portrait Section --}}
      <div class="portrait-section">
        <div class="portrait-frame portrait-clickable" data-action="change-portrait">
          <img src="{{actor.img}}" alt="{{actor.name}}" class="character-portrait" title="Click to change portrait">
          <div class="portrait-overlay">
            <i class="fas fa-camera"></i>
          </div>
        </div>
      </div>
      
      {{!-- Name and Concept Section --}}
      <div class="name-section">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Character Name" class="character-name"/>
        <input name="system.profile.concept" type="text" value="{{system.profile.concept}}" placeholder="Concept" class="character-concept"/>
        {{!-- Theme toggle --}}
        <button type="button" class="theme-toggle-btn" data-current-theme="{{sheetTheme}}"
                title="Toggle sheet theme">
          {{#if (eq sheetTheme "dark")}}
            <i class="fas fa-sun"></i> Blue Planet
          {{else}}
            <i class="fas fa-moon"></i> Dark
          {{/if}}
        </button>
      </div>
      
      {{!-- Right Stats Section --}}
      <div class="header-stats">
        <div class="stat-row">
          <label>Tier:</label>
          <select name="system.tier" class="tier-select">
            <option value="everyday">Everyday</option>
            <option value="exceptional">Exceptional</option>
            <option value="elite">Elite</option>
          </select>
        </div>
        
        <div class="stat-row">
          <label>C.H.I.P.S:</label>
          <div class="pip-track chips-track">
            {{#each (range 20) as |i|}}
              <div class="pip chip-pip {{#if (gte system.advancement.chips (add i 1))}}filled{{/if}}" data-value="{{add i 1}}"></div>
            {{/each}}
            <span class="pip-value">{{system.advancement.chips}}</span>
          </div>
        </div>
        
        <div class="stat-row">
          <label>Reputation:</label>
          <div class="pip-track reputation-track">
            {{#each (range 25) as |i|}}
              <div class="pip reputation-pip {{#if (gte system.profile.reputation.level (add i 1))}}filled{{/if}}" data-value="{{add i 1}}"></div>
            {{/each}}
            <span class="pip-value">{{system.profile.reputation.level}}</span>
          </div>
        </div>
      </div>
    </div>
  </header>


  <div class="sheet-main">
    {{!-- Left Sidebar --}}
    <aside class="sidebar">
      {{!-- Strain --}}
      <section class="strain">
        <h3>STRAIN</h3>
        <div class="strain-type">
          <label>Mental:</label>
          <div class="pip-track strain-track">
            {{#each (range system.strain.mental.max) as |i|}}
              <div class="pip strain-pip mental-strain {{#if (gte system.strain.mental.value (add i 1))}}filled{{/if}}" data-value="{{add i 1}}" data-type="mental"></div>
            {{/each}}
            <span class="pip-value">{{system.strain.mental.value}}/{{system.strain.mental.max}}</span>
          </div>
        </div>
        
        <div class="strain-type">
          <label>Physical:</label>
          <div class="pip-track strain-track">
            {{#each (range system.strain.physical.max) as |i|}}
              <div class="pip strain-pip physical-strain {{#if (gte system.strain.physical.value (add i 1))}}filled{{/if}}" data-value="{{add i 1}}" data-type="physical"></div>
            {{/each}}
            <span class="pip-value">{{system.strain.physical.value}}/{{system.strain.physical.max}}</span>
          </div>
        </div>
        
        {{!-- Strain Recovery Buttons --}}
        <div class="strain-recovery">
          <button type="button" class="strain-recover" title="Partial Recovery - Rest and medical attention">
            <i class="fas fa-heart"></i> Recover
          </button>
          <button type="button" class="strain-recover-all" title="Full Recovery - Extended rest with proper care">
            <i class="fas fa-spa"></i> Full Rest
          </button>
        </div>
      </section>

      {{!-- Wounds --}}
      <section class="wounds">
        <h3>HERIDAS</h3>
        <div class="wound-type">
          <label>Minor (-1 each):</label>
          <div class="pip-track wound-track">
            {{#each (range 5) as |i|}}
              <div class="pip wound-pip minor-wound {{#if (gte system.wounds.minor (add i 1))}}filled{{/if}}" data-value="{{add i 1}}" data-type="minor"></div>
            {{/each}}
            <span class="wound-penalty">(-{{system.wounds.minor}})</span>
          </div>
        </div>
        
        <div class="wound-type">
          <label>Major (-2 each):</label>
          <div class="pip-track wound-track">
            {{#each (range 4) as |i|}}
              <div class="pip wound-pip major-wound {{#if (gte system.wounds.major (add i 1))}}filled{{/if}}" data-value="{{add i 1}}" data-type="major"></div>
            {{/each}}
            <span class="wound-penalty">(-{{multiply system.wounds.major 2}})</span>
          </div>
        </div>
        
        <div class="wound-type">
          <label>Mortal (-3 each):</label>
          <div class="pip-track wound-track">
            {{#each (range 3) as |i|}}
              <div class="pip wound-pip mortal-wound {{#if (gte system.wounds.mortal (add i 1))}}filled{{/if}}" data-value="{{add i 1}}" data-type="mortal"></div>
            {{/each}}
            <span class="wound-penalty">(-{{multiply system.wounds.mortal 3}})</span>
          </div>
        </div>
        
        <div class="total-penalty">
          <strong>Total Penalty: {{system.totalWoundPenalty}}</strong>
        </div>
      </section>

      {{!-- Status --}}
      <section class="status">
        <h3>ESTADO</h3>
        <div class="status-condition">
          <input name="system.status.condition" type="text" value="{{system.status.condition}}" placeholder="Current Status"/>
        </div>
      </section>
    </aside>

    {{!-- Main Content --}}
    <section class="main-content">
      {{!-- Navigation Tabs --}}
      <nav class="sheet-tabs" data-group="primary">
        <a class="item active" data-tab="abilities">ABILITIES</a>
        <a class="item" data-tab="capacities">CAPACITIES</a>
        <a class="item" data-tab="items">ITEMS</a>
        <a class="item" data-tab="profile">PROFILE</a>
      </nav>

      {{!-- Tab Content --}}
      <section class="sheet-body">
        
        {{!-- Abilities Tab (Attributes + Skills) --}}
        <div class="tab abilities active" data-group="primary" data-tab="abilities">
          <div class="abilities-layout">
            {{!-- Left Side: Attributes --}}
            <div class="attributes-section">
              <div class="attributes-grid">
                {{#each system.attributes as |attr key|}}
                <div class="attribute-group expanded">
                  <div class="attribute-header">
                    <i class="fas fa-dice-d10 attribute-roll rollable" data-attribute="{{key}}" title="Roll {{capitalize key}}"></i>
                    <label class="attribute-name rollable attribute-roll" data-attribute="{{key}}" title="Click to roll {{capitalize key}}">{{uppercase key}}</label>
                    <input type="number" name="system.attributes.{{key}}.value" value="{{attr.value}}" class="attribute-value">
                  </div>
                  
                  {{#if attr.focus}}
                  <div class="focus-attributes">
                    <div class="focus-item">
                      <i class="fas fa-dice-d10 attribute-roll rollable" data-attribute="{{key}}" data-focus="primary" title="Roll Focus"></i>
                      <input type="text" name="system.attributes.{{key}}.focus.primary.name" value="{{attr.focus.primary.name}}" 
                             placeholder="Focus 1" class="focus-name rollable attribute-roll" data-attribute="{{key}}" data-focus="primary" title="Click to roll focus">
                      <span class="focus-value">({{attr.focus.primary.value}})</span>
                    </div>
                    
                    <div class="focus-item">
                      <i class="fas fa-dice-d10 attribute-roll rollable" data-attribute="{{key}}" data-focus="secondary" title="Roll Focus"></i>
                      <input type="text" name="system.attributes.{{key}}.focus.secondary.name" value="{{attr.focus.secondary.name}}" 
                             placeholder="Focus 2" class="focus-name rollable attribute-roll" data-attribute="{{key}}" data-focus="secondary" title="Click to roll focus">
                      <span class="focus-value">({{attr.focus.secondary.value}})</span>
                    </div>
                  </div>
                  {{/if}}
                  
                  {{#if attr.dual}}
                  <div class="dual-attribute">
                    <label>Dual:</label>
                    <input type="number" name="system.attributes.{{key}}.dual" value="{{attr.dual}}" class="dual-value">
                  </div>
                  {{/if}}
                </div>
                {{/each}}
              </div>
            </div>
            
            {{!-- Right Side: Skills --}}
            <div class="skills-section">
              <h3>Skill Sets</h3>
              
              <div class="skill-list">
                {{!-- Specialty Skills Group --}}
                {{#if skillsByLevel.specialty.length}}
                <div class="skill-level-group specialty-group">
                  <h4 class="skill-level-header"><i class="fas fa-star"></i> Specialty Skills (3d10kl)</h4>
                  {{#each skillsByLevel.specialty as |skill|}}
                  {{> skillItem skill=skill}}
                  {{/each}}
                </div>
                {{/if}}
                
                {{!-- Core Skills Group --}}
                {{#if skillsByLevel.core.length}}
                <div class="skill-level-group core-group">
                  <h4 class="skill-level-header"><i class="fas fa-certificate"></i> Core Skills (2d10kl)</h4>
                  {{#each skillsByLevel.core as |skill|}}
                  {{> skillItem skill=skill}}
                  {{/each}}
                </div>
                {{/if}}
                
                {{!-- General Skills Group --}}
                {{#if skillsByLevel.general.length}}
                <div class="skill-level-group general-group">
                  <h4 class="skill-level-header"><i class="fas fa-circle"></i> General Skills (1d10)</h4>
                  {{#each skillsByLevel.general as |skill|}}
                  {{> skillItem skill=skill}}
                  {{/each}}
                </div>
                {{/if}}
                
                {{!-- No Skills Message --}}
                {{#unless skillSets.length}}
                <div class="no-skills-message">
                  <p><em>No skills created yet. Click "Add Skill Set" to create your first skill.</em></p>
                </div>
                {{/unless}}
                
                <div class="skill-controls">
                  <a class="item-control item-create" data-type="skill" title="Create Skill"><i class="fas fa-plus"></i> Add Skill Set</a>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        {{!-- Capacities Tab (Biomods & Cyberware) --}}
        <div class="tab capacities" data-group="primary" data-tab="capacities">
          <div class="capacities-section">
            
            {{!-- Biomods Section --}}
            <div class="biomods-section">
              <h3><i class="fas fa-dna"></i> Biomodifications</h3>
              <div class="biomods-description">
                <p><em>Biological enhancements and genetic modifications that alter the character's physiology.</em></p>
              </div>
              
              {{#if biomods.length}}
              <ol class="item-list biomod-list">
                {{#each biomods as |item id|}}
                <li class="item flexrow biomod-item {{#unless item.system.active}}inactive{{/unless}}" data-item-id="{{item._id}}">
                  <div class="biomod-info-row">
                    <div class="biomod-basic">
                      <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                      <h4 class="biomod-name">{{item.name}}</h4>
                      {{#if item.system.type}}
                      <span class="biomod-type-badge">{{capitalize item.system.type}}</span>
                      {{/if}}
                    </div>
                    
                    <div class="biomod-stats-compact">
                      {{!-- Single line compact info --}}
                      <div class="biomod-info-inline">
                        {{#if item.system.type}}<span class="info-badge type-badge">{{capitalize item.system.type}}</span>{{/if}}
                        {{#if item.system.availability}}<span class="info-badge avail-badge">{{capitalize item.system.availability}}</span>{{/if}}
                        
                        {{!-- Attribute bonuses (abbreviated) --}}
                        {{#if item.system.attributes}}
                          {{#each item.system.attributes as |bonus attr|}}
                            {{#if (ne bonus 0)}}
                            <span class="attr-compact {{#if (gt bonus 0)}}pos{{else}}neg{{/if}}">
                              {{#if (eq attr "cognition")}}COG{{else if (eq attr "psyche")}}PSY{{else if (eq attr "coordination")}}COO{{else if (eq attr "physique")}}PHY{{else}}{{capitalize attr}}{{/if}}{{#if (gt bonus 0)}}+{{/if}}{{bonus}}
                            </span>
                            {{/if}}
                          {{/each}}
                        {{/if}}
                        
                        {{!-- Mechanics (ultra compact) --}}
                        {{#if (hasMechanics item)}}
                          {{#if (gt (safeGet item.system "mechanics.initiative_bonus") 0)}}<span class="mech-compact init">I+{{safeGet item.system "mechanics.initiative_bonus"}}</span>{{/if}}
                          {{#if (gt (safeGet item.system "mechanics.natural_armor") 0)}}<span class="mech-compact armor">A{{safeGet item.system "mechanics.natural_armor"}}</span>{{/if}}
                          {{#if (gt (safeGet item.system "mechanics.unarmed_damage_bonus") 0)}}<span class="mech-compact dmg">D+{{safeGet item.system "mechanics.unarmed_damage_bonus"}}</span>{{/if}}
                          {{#if (gt (safeGet item.system "mechanics.wound_penalty_reduction.major") 0)}}<span class="mech-compact wound">Maj-{{safeGet item.system "mechanics.wound_penalty_reduction.major"}}</span>{{/if}}
                          {{#if (gt (safeGet item.system "mechanics.wound_penalty_reduction.mortal") 0)}}<span class="mech-compact wound">Mor-{{safeGet item.system "mechanics.wound_penalty_reduction.mortal"}}</span>{{/if}}
                        {{/if}}
                        
                        {{!-- Effects and cost --}}
                        {{#if item.system.effects}}<span class="info-badge effects-badge">{{item.system.effects.length}}fx</span>{{/if}}
                        {{#if item.system.cost}}<span class="info-badge cost-badge">¤{{item.system.cost}}</span>{{/if}}
                      </div>
                    </div>
                    
                    <div class="item-controls">
                      {{#if item.system.active}}
                      <a class="item-control item-deactivate" data-item-id="{{item._id}}" title="Deactivate Biomod"><i class="fas fa-toggle-on"></i></a>
                      {{else}}
                      <a class="item-control item-activate" data-item-id="{{item._id}}" title="Activate Biomod"><i class="fas fa-toggle-off"></i></a>
                      {{/if}}
                      <a class="item-control item-chat" data-item-id="{{item._id}}" title="Show in Chat"><i class="fas fa-comment"></i></a>
                      <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                      <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                    </div>
                  </div>
                </li>
                {{/each}}
              </ol>
              {{else}}
              <div class="no-items-message">
                <p><em>No biomodifications installed. Drag biomod items here or create new ones.</em></p>
              </div>
              {{/if}}
              
              <div class="item-controls">
                <a class="item-control item-create item-create-button" data-type="biomod" title="Create Biomod"><i class="fas fa-plus"></i> Add Biomod</a>
              </div>
            </div>
            
            {{!-- Cyberware Section --}}
            <div class="cyberware-section">
              <h3><i class="fas fa-microchip"></i> Cyberware</h3>
              <div class="cyberware-description">
                <p><em>Technological implants and cybernetic enhancements that augment the character's capabilities.</em></p>
              </div>
              
              {{#if cyberware.length}}
              <ol class="item-list cyberware-list">
                {{#each cyberware as |item id|}}
                <li class="item flexrow cyberware-item {{#unless item.system.active}}inactive{{/unless}}" data-item-id="{{item._id}}">
                  <div class="cyberware-info-row">
                    <div class="cyberware-basic">
                      <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                      <h4 class="cyberware-name">{{item.name}}</h4>
                      {{#if item.system.type}}
                      <span class="cyberware-type-badge">{{capitalize item.system.type}}</span>
                      {{/if}}
                    </div>
                    
                    <div class="cyberware-stats">
                      {{!-- Type and Availability --}}
                      <div class="cyberware-basic-info">
                        {{#if item.system.type}}
                        <span class="cyberware-type-badge">{{capitalize item.system.type}}</span>
                        {{/if}}
                        {{#if item.system.availability}}
                        <span class="cyberware-availability-badge">{{capitalize item.system.availability}}</span>
                        {{/if}}
                      </div>
                      
                      {{!-- Show attribute bonuses if any --}}
                      {{#if item.system.attributes}}
                      <div class="cyberware-attributes">
                        {{#each item.system.attributes as |bonus attr|}}
                          {{#if (ne bonus 0)}}
                          <span class="attr-bonus {{#if (gt bonus 0)}}positive{{else}}negative{{/if}}">
                            {{capitalize attr}}: {{#if (gt bonus 0)}}+{{/if}}{{bonus}}
                          </span>
                          {{/if}}
                        {{/each}}
                      </div>
                      {{/if}}
                      
                      {{!-- Mechanics (simplified, only show non-zero values) --}}
                      {{#if (hasMechanics item)}}
                      <div class="cyberware-mechanics-compact">
                        {{#if (gt (safeGet item.system "mechanics.initiative_bonus") 0)}}
                        <span class="mechanics-bonus init-bonus">Init: +{{safeGet item.system "mechanics.initiative_bonus"}}</span>
                        {{/if}}
                        {{#if (gt (safeGet item.system "mechanics.natural_armor") 0)}}
                        <span class="mechanics-bonus armor-bonus">Armor: {{safeGet item.system "mechanics.natural_armor"}}</span>
                        {{/if}}
                        {{#if (gt (safeGet item.system "mechanics.unarmed_damage_bonus") 0)}}
                        <span class="mechanics-bonus damage-bonus">Dmg: +{{safeGet item.system "mechanics.unarmed_damage_bonus"}}</span>
                        {{/if}}
                        {{#if (gt (safeGet item.system "mechanics.wound_penalty_reduction.major") 0)}}
                        <span class="mechanics-bonus wound-bonus">Major: -{{safeGet item.system "mechanics.wound_penalty_reduction.major"}}</span>
                        {{/if}}
                        {{#if (gt (safeGet item.system "mechanics.wound_penalty_reduction.mortal") 0)}}
                        <span class="mechanics-bonus wound-bonus">Mortal: -{{safeGet item.system "mechanics.wound_penalty_reduction.mortal"}}</span>
                        {{/if}}
                      </div>
                      {{/if}}
                      
                      {{!-- Effects count --}}
                      {{#if item.system.effects}}
                      <div class="cyberware-effects-preview">
                        <span class="effects-count">{{item.system.effects.length}} effect{{#unless (eq item.system.effects.length 1)}}s{{/unless}}</span>
                      </div>
                      {{/if}}
                      
                      {{#if item.system.cost}}
                      <span class="cyberware-cost">¤{{item.system.cost}}</span>
                      {{/if}}
                    </div>
                    
                    <div class="item-controls">
                      {{#if item.system.active}}
                      <a class="item-control item-deactivate" data-item-id="{{item._id}}" title="Deactivate Cyberware"><i class="fas fa-toggle-on"></i></a>
                      {{else}}
                      <a class="item-control item-activate" data-item-id="{{item._id}}" title="Activate Cyberware"><i class="fas fa-toggle-off"></i></a>
                      {{/if}}
                      <a class="item-control item-chat" data-item-id="{{item._id}}" title="Show in Chat"><i class="fas fa-comment"></i></a>
                      <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                      <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                    </div>
                  </div>
                </li>
                {{/each}}
              </ol>
              {{else}}
              <div class="no-items-message">
                <p><em>No cyberware installed. Drag cyberware items here or create new ones.</em></p>
              </div>
              {{/if}}
              
              <div class="item-controls">
                <a class="item-control item-create item-create-button" data-type="cyberware" title="Create Cyberware"><i class="fas fa-plus"></i> Add Cyberware</a>
              </div>
            </div>
            
            {{!-- Capacity Summary --}}
            <div class="capacity-summary">
              <h3><i class="fas fa-chart-bar"></i> Capacity Summary</h3>
              <div class="summary-grid">
                <div class="summary-item">
                  <label>Total Biomods:</label>
                  <span class="summary-value">{{biomods.length}}</span>
                </div>
                <div class="summary-item">
                  <label>Active Biomods:</label>
                  <span class="summary-value">{{activeBiomodCount}}</span>
                </div>
                <div class="summary-item">
                  <label>Total Cyberware:</label>
                  <span class="summary-value">{{cyberware.length}}</span>
                </div>
                <div class="summary-item">
                  <label>Active Cyberware:</label>
                  <span class="summary-value">{{activeCyberwareCount}}</span>
                </div>
                <div class="summary-item">
                  <label>Total Strain Cost:</label>
                  <span class="summary-value strain-cost">{{totalCapacityStrainCost}}</span>
                </div>
              </div>
            </div>
            
          </div>
        </div>

        {{!-- Profile Tab --}}
        <div class="tab profile" data-group="primary" data-tab="profile">
          <div class="profile-content">
            <div class="profile-grid">
              {{!-- Left Column --}}
              <div class="profile-left">
                <section class="profile-section">
                  <h3>Motivation</h3>
                  <textarea name="system.profile.motivation" class="profile-textarea" placeholder="What drives this character?">{{system.profile.motivation}}</textarea>
                </section>
                
                <section class="profile-section">
                  <h3>Attitude</h3>
                  <textarea name="system.profile.attitude" class="profile-textarea" placeholder="How does this character approach life?">{{system.profile.attitude}}</textarea>
                </section>
                
                <section class="profile-section">
                  <h3>Goal</h3>
                  <textarea name="system.profile.goal" class="profile-textarea" placeholder="What is this character trying to achieve?">{{system.profile.goal}}</textarea>
                </section>
                
                <section class="profile-section">
                  <h3>Especies (Species)</h3>
                  <input type="text" name="system.species" value="{{system.species}}" placeholder="Human, Modified Human, Cetacean, etc." class="profile-input">
                </section>
              </div>
              
              {{!-- Right Column --}}
              <div class="profile-right">
                <section class="profile-section">
                  <h3>Tags</h3>
                  <div class="tags-container">
                    {{#each system.tags as |tag|}}
                    <div class="tag-item">
                      <input type="text" name="system.tags.{{@index}}" value="{{tag}}" placeholder="Tag" class="tag-input">
                      <button type="button" class="tag-delete" data-index="{{@index}}">×</button>
                    </div>
                    {{/each}}
                    <button type="button" class="add-tag-btn"><i class="fas fa-plus"></i> Add Tag</button>
                  </div>
                </section>
                
                <section class="profile-section">
                  <h3>Tracks</h3>
                  <div class="tracks-container">
                    {{#each system.tracks as |track key|}}
                    <div class="track-item">
                      <input type="text" name="system.tracks.{{key}}.name" value="{{track.name}}" placeholder="Track Name" class="track-name">
                      <input type="number" name="system.tracks.{{key}}.value" value="{{track.value}}" min="0" max="10" class="track-value">
                      <button type="button" class="track-delete" data-key="{{key}}">×</button>
                    </div>
                    {{/each}}
                    <button type="button" class="add-track-btn"><i class="fas fa-plus"></i> Add Track</button>
                  </div>
                </section>
                
                <section class="profile-section">
                  <h3>Ties</h3>
                  <div class="ties-container">
                    {{#each system.ties as |tie|}}
                    <div class="tie-item">
                      <input type="text" name="system.ties.{{@index}}.name" value="{{tie.name}}" placeholder="Person/Organization" class="tie-name">
                      <select name="system.ties.{{@index}}.relationship" class="tie-relationship">
                        <option value="ally" {{#if (eq tie.relationship "ally")}}selected{{/if}}>Ally</option>
                        <option value="contact" {{#if (eq tie.relationship "contact")}}selected{{/if}}>Contact</option>
                        <option value="rival" {{#if (eq tie.relationship "rival")}}selected{{/if}}>Rival</option>
                        <option value="enemy" {{#if (eq tie.relationship "enemy")}}selected{{/if}}>Enemy</option>
                        <option value="family" {{#if (eq tie.relationship "family")}}selected{{/if}}>Family</option>
                        <option value="friend" {{#if (eq tie.relationship "friend")}}selected{{/if}}>Friend</option>
                      </select>
                      <textarea name="system.ties.{{@index}}.description" class="tie-description" placeholder="Relationship details">{{tie.description}}</textarea>
                      <button type="button" class="tie-delete" data-index="{{@index}}">×</button>
                    </div>
                    {{/each}}
                    <button type="button" class="add-tie-btn"><i class="fas fa-plus"></i> Add Tie</button>
                  </div>
                </section>
              </div>
            </div>
          </div>
        </div>
        
        {{!-- Items Tab --}}
        <div class="tab items" data-group="primary" data-tab="items">
          <div class="items-section">
            <h3>Weapons</h3>
            <ol class="item-list weapon-list">
              {{#each weapons as |item id|}}
              <li class="item flexrow weapon-item {{#unless item.system.equipped}}unequipped{{/unless}}" data-item-id="{{item._id}}">
                <div class="weapon-info-row">
                  <div class="weapon-basic">
                    {{#if item.system.equipped}}
                    <a class="weapon-attack-roll" data-item-id="{{item._id}}" title="Roll Attack" style="color: #4a90e2; margin-right: 3px;"><i class="fas fa-sword"></i></a>
                    {{else}}
                    <span class="weapon-attack-roll-disabled" title="Weapon not equipped" style="color: #666; margin-right: 3px;"><i class="fas fa-sword"></i></span>
                    {{/if}}
                    {{#if (and item.system.damage item.system.equipped)}}
                    <a class="weapon-damage-roll" data-item-id="{{item._id}}" title="Roll Damage" style="color: #dc3545; margin-right: 3px;"><i class="fas fa-dice-d10"></i></a>
                    {{else if item.system.damage}}
                    <span class="weapon-damage-roll-disabled" title="Weapon not equipped" style="color: #666; margin-right: 3px;"><i class="fas fa-dice-d10"></i></span>
                    {{/if}}
                    <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="20" height="20"/></div>
                    <h4 class="weapon-name rollable" data-roll-type="item" title="Click to Attack" style="cursor: pointer; color: #4a90e2; text-decoration: underline;">{{item.name}}</h4>
                  </div>
                  
                  <div class="weapon-stats-compact">
                    <span class="weapon-type">{{capitalize item.system.weapon_type}}</span>
                    {{#if item.system.damage}}
                    <span class="weapon-damage">DR {{item.system.damage}}</span>
                    {{/if}}
                    {{#if (and item.system.effective_range (ne item.system.weapon_type "melee"))}}
                    <span class="weapon-range">{{item.system.effective_range}}m</span>
                    {{/if}}
                    {{#if (ne item.system.weapon_type "melee")}}
                      {{#if item.system.loaded_ammunition}}
                      <span class="weapon-ammo" style="color: #32cd32;">{{item.system.current_ammo}}/{{item.system.magazine_capacity}}</span>
                      <span class="weapon-ammo-type" style="color: #87ceeb; font-size: 10px;">({{titleCase item.system.loaded_ammunition.ammo_type}})</span>
                      {{else}}
                      <span class="weapon-ammo" style="color: #dc3545;">No ammo loaded</span>
                      {{/if}}
                    {{/if}}
                    {{#if item.system.cost}}
                    <span class="weapon-cost">¤{{item.system.cost}}</span>
                    {{/if}}
                  </div>
                  
                  <div class="item-controls">
                    {{#if item.system.equipped}}
                    <a class="item-control item-unequip" data-item-id="{{item._id}}" title="Unequip Weapon"><i class="fas fa-toggle-on"></i></a>
                    {{else}}
                    <a class="item-control item-equip" data-item-id="{{item._id}}" title="Equip Weapon"><i class="fas fa-toggle-off"></i></a>
                    {{/if}}
                    <a class="item-control item-chat" data-item-id="{{item._id}}" title="Show in Chat"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                  </div>
                </div>
              </li>
              {{/each}}
            </ol>
            <div class="item-controls">
              <a class="item-control item-create item-create-button" data-type="weapon" title="Create Weapon"><i class="fas fa-plus"></i> Add Weapon</a>
            </div>
          </div>

          <div class="items-section">
            <h3>Ammunition</h3>
            <ol class="item-list ammunition-list-compact">
              {{#each ammunition as |item id|}}
              <li class="item flexrow ammunition-item-compact" data-item-id="{{item._id}}">
                <div class="ammunition-compact-row">
                  {{!-- Item Image --}}
                  <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="20" height="20"/></div>
                  
                  {{!-- Name and Type --}}
                  <div class="ammo-info">
                    <h4 class="ammo-name">{{item.name}}</h4>
                    <span class="ammo-type">{{titleCase item.system.ammo_type}}</span>
                  </div>
                  
                  {{!-- Magazines --}}
                  <div class="ammo-mags">
                    <i class="fas fa-archive" title="Magazines"></i>
                    <span class="ammo-quantity">{{item.system.quantity}}</span>
                  </div>
                  
                  {{!-- Capacity --}}
                  <div class="ammo-cap">
                    <input type="number" class="ammo-capacity-input" name="system.package_size" value="{{item.system.package_size}}" min="1" max="1000" data-item-id="{{item._id}}">
                  </div>
                  
                  {{!-- Current Ammo --}}
                  <div class="ammo-current">
                    <input type="number" class="current-ammo-input" value="{{subtract (multiply item.system.quantity item.system.package_size) item.system.rounds_fired}}" min="0" max="{{multiply item.system.quantity item.system.package_size}}" data-item-id="{{item._id}}">
                    <span class="total-rounds">/{{multiply item.system.quantity item.system.package_size}}</span>
                  </div>
                  
                  {{!-- Bonuses (Compact) --}}
                  <div class="ammo-bonuses-compact">
                    {{#if (hasBonus item.system.attack_modifier)}}
                    <span class="bonus-compact attack-bonus" title="Attack Bonus">AB{{#if (gte item.system.attack_modifier 0)}}+{{/if}}{{item.system.attack_modifier}}</span>
                    {{/if}}
                    {{#if (hasBonus item.system.damage_modifier)}}
                    <span class="bonus-compact damage-bonus" title="Damage Rating Bonus">DR{{#if (gte item.system.damage_modifier 0)}}+{{/if}}{{item.system.damage_modifier}}</span>
                    {{/if}}
                    {{#if (hasBonus item.system.range_modifier)}}
                    <span class="bonus-compact range-bonus" title="Range Modifier">RNG{{item.system.range_modifier}}%</span>
                    {{/if}}
                    {{#if (hasBonus item.system.penetration)}}
                    <span class="bonus-compact penetration-bonus" title="Penetration">PEN{{item.system.penetration}}</span>
                    {{/if}}
                  </div>
                  
                  {{!-- Load Button --}}
                  <div class="ammo-load">
                    <select class="compatible-weapon-select-compact" data-item-id="{{item._id}}">
                      <option value="">Load...</option>
                      {{#each ../weapons as |weapon|}}
                        {{#if (isCompatibleAmmo item weapon)}}
                        <option value="{{weapon._id}}">{{weapon.name}}</option>
                        {{/if}}
                      {{/each}}
                    </select>
                    <button type="button" class="load-ammo-btn-compact" data-ammo-id="{{item._id}}" title="Load weapon">
                      <i class="fas fa-arrow-right"></i>
                    </button>
                  </div>
                  
                  {{!-- Controls --}}
                  <div class="item-controls">
                    <a class="item-control item-chat" data-item-id="{{item._id}}" title="Show in Chat"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                  </div>
                </div>
              </li>
              {{/each}}
            </ol>
            <div class="item-controls">
              <a class="item-control item-create item-create-button" data-type="ammunition" title="Create Ammunition"><i class="fas fa-plus"></i> Add Ammunition</a>
            </div>
          </div>

          <div class="items-section">
            <h3>Equipment</h3>
            <ol class="item-list equipment-list">
              {{#each equipment as |item id|}}
              <li class="item flexrow equipment-item {{#unless item.system.equipped}}unequipped{{/unless}}" data-item-id="{{item._id}}">
                <div class="equipment-info-row">
                  <div class="equipment-basic">
                    <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="20" height="20"/></div>
                    <div class="equipment-name-section">
                      <h4 class="equipment-name">
                        {{#if item.system.quantity}}
                        <span class="equipment-quantity">[{{item.system.quantity}}]</span>
                        {{/if}}
                        <span class="equipment-title">{{item.name}}</span>
                      </h4>
                    </div>
                  </div>
                  
                  <div class="equipment-stats-compact">
                    {{#if item.system.type}}
                    <span class="equipment-type">{{capitalize item.system.type}}</span>
                    {{/if}}
                    {{#if item.system.cost}}
                    <span class="equipment-cost">¤{{item.system.cost}}</span>
                    {{/if}}
                    {{#if (and item.system.weight (not (or (includes item.system.category "armor") (eq item.system.type "armor") (eq item.system.type "protection"))))}}
                    <span class="equipment-weight">{{item.system.weight}}kg</span>
                    {{/if}}
                  </div>

                  {{!-- Armor & Protection compact tracker --}}
{{#if (or (includes item.system.category "armor") (or (eq item.system.type "armor") (eq item.system.type "protection")))}}
                  <div class="armor-inline" style="display: flex; align-items: center; gap: 8px;">
                    <!-- Pips tracker -->
                    <div class="pip-track armor-dura-track" data-item-id="{{item._id}}">
                      {{#each (pips item.system.durability item.system.max_durability) as |pip|}}
                      <span class="pip armor-pip {{#if pip.checked}}filled{{/if}}" data-index="{{pip.index}}"></span>
                      {{/each}}
                    </div>
                    <!-- Controls and inputs -->
                    <div class="durability-input-group" style="display: flex; align-items: center; gap: 6px;">
                      <button type="button" class="armor-dura-minus" data-item-id="{{item._id}}" title="Reduce durability" style="width: 20px; height: 20px; line-height: 20px; padding: 0; display: inline-flex; align-items: center; justify-content: center;"><i class="fas fa-minus" style="font-size: 10px;"></i></button>
                      <input type="number" class="armor-dura-input" data-item-id="{{item._id}}" value="{{item.system.durability}}" min="0" style="width: 36px; height: 20px; text-align: center;">
                      <span style="font-size: 11px; color: #bbb;">/</span>
                      <input type="number" class="armor-dura-max-input" data-item-id="{{item._id}}" value="{{item.system.max_durability}}" min="1" style="width: 36px; height: 20px; text-align: center;">
                      <button type="button" class="armor-dura-plus" data-item-id="{{item._id}}" title="Increase durability" style="width: 20px; height: 20px; line-height: 20px; padding: 0; display: inline-flex; align-items: center; justify-content: center;"><i class="fas fa-plus" style="font-size: 10px;"></i></button>
                    </div>
                    <!-- Dimensions & weight -->
                    <div class="armor-weight" style="font-size: 11px; color: #bbb; white-space: nowrap;">
                      {{#if item.system.dimensions}}<span class="dim-label">{{capitalize item.system.dimensions}}</span>{{/if}}
                      {{#if item.system.weight}}<span class="dim-weight"> - {{item.system.weight}}kg</span>{{/if}}
                    </div>
                  </div>
                  {{/if}}
                  
                  <div class="item-controls">
                    {{#if item.system.equipped}}
                    <a class="item-control item-unequip" data-item-id="{{item._id}}" title="Unequip Equipment"><i class="fas fa-toggle-on"></i></a>
                    {{else}}
                    <a class="item-control item-equip" data-item-id="{{item._id}}" title="Equip Equipment"><i class="fas fa-toggle-off"></i></a>
                    {{/if}}
                    <a class="item-control item-chat" data-item-id="{{item._id}}" title="Show in Chat"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                  </div>
                </div>
              </li>
              {{/each}}
            </ol>
            <div class="item-controls">
              <a class="item-control item-create item-create-button" data-type="equipment" title="Create Equipment"><i class="fas fa-plus"></i> Add Equipment</a>
            </div>
          </div>

        </div>


      </section>
    </section>
  </div>

</form>

{{!-- Compact Skill Item Partial --}}
{{#*inline "skillItem"}}
<div class="skill-item" data-skill-id="{{skill.id}}">
  <div class="skill-header">
    <div class="skill-main-info">
      <i class="fas fa-dice-d10 skill-roll rollable" data-skill="{{skill.id}}" title="Roll {{skill.label}}"></i>
      <span class="skill-name rollable skill-roll" data-skill="{{skill.id}}" title="Click to roll {{skill.label}}">{{skill.label}}</span>
      <span class="skill-aspect aspect-{{skill.aspect}}" title="{{capitalize skill.aspect}} skill">{{capitalize skill.aspect}}</span>
      <span class="skill-rank" title="Skill Rank">(Rank <input type="number" name="system.skills.{{skill.id}}.rank" value="{{skill.rank}}" min="1" max="6" class="skill-rank-input">)</span>
    </div>
    <div class="skill-actions">
      <i class="fas fa-edit skill-edit" data-skill-id="{{skill.id}}" title="Edit {{skill.label}}"></i>
      <i class="fas fa-trash skill-delete" data-skill-id="{{skill.id}}" title="Delete {{skill.label}}"></i>
    </div>
  </div>
</div>
{{/inline}}
